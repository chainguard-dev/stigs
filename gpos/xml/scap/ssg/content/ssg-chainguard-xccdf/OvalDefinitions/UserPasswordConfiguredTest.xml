  <definitions>
    <definition id="oval:org.example:def:3" version="1" class="compliance">
      <metadata>
        <title>No interactive hashed passwords in /etc/shadow</title>
        <description>Chainguard container images must not ship interactive shadow password entries; every account must have its shadow field locked (&quot;!&quot; or &quot;*&quot;). This check FAILS if any line in /etc/shadow matches the pattern user:$hash:... indicating a stored hashed password, on the premise that hardened images have no interactive logins.</description>
        <reference source="Custom"/>
        <affected family="unix">
          <platform>Chainguard</platform>
        </affected>
      </metadata>
      <criteria>
        <criterion comment="No /etc/shadow entry carries a hashed interactive password" test_ref="oval:org.example:tst:6"/>
      </criteria>
    </definition>
  </definitions>
  <tests>
    <textfilecontent54_test xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" check="all" check_existence="none_exist" comment="Fail if any /etc/shadow line stores a hashed password ($...)" id="oval:org.example:tst:6" version="1">
      <object object_ref="oval:org.example:obj:6"/>
    </textfilecontent54_test>
  </tests>
  <objects>
    <!-- Match lines of the form "user:$<hash>:..." in /etc/shadow. Locked
         accounts ("user:!:..." or "user:*:...") do not match and are ignored. -->
    <textfilecontent54_object xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" id="oval:org.example:obj:6" version="1">
      <path>/etc</path>
      <filename>shadow</filename>
      <pattern operation="pattern match">^[^:]+:\$[^\n]*:</pattern>
      <instance datatype="int">1</instance>
    </textfilecontent54_object>
  </objects>
</oval_definitions>
