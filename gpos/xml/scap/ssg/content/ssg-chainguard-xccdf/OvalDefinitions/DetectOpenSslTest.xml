  <objects>
    <!-- obj:1 collects any file under /etc/ssl whose basename contains "fipsmodule"
         (e.g. /etc/ssl/fipsmodule.cnf). Without <unix:behaviors> the default
         recurse_direction is "none" so OVAL never looks inside /etc/ssl and the
         pattern is silently never applied. -->
    <unix:file_object xmlns:unix="http://oval.mitre.org/XMLSchema/oval-definitions-5#unix" id="oval:org.OpenSsl:obj:1" version="1">
      <unix:behaviors recurse="symlinks and directories" recurse_direction="down" max_depth="-1" recurse_file_system="local"/>
      <unix:path>/etc/ssl</unix:path>
      <unix:filename operation="pattern match">(?=.*fipsmodule).*</unix:filename>
    </unix:file_object>
    <!-- obj:2 collects any file under /etc/ssl whose basename contains "openssl"
         (e.g. /etc/ssl/openssl.cnf). Same recursion rationale as obj:1. -->
    <unix:file_object xmlns:unix="http://oval.mitre.org/XMLSchema/oval-definitions-5#unix" id="oval:org.OpenSsl:obj:2" version="1">
      <unix:behaviors recurse="symlinks and directories" recurse_direction="down" max_depth="-1" recurse_file_system="local"/>
      <unix:path>/etc/ssl</unix:path>
      <unix:filename operation="pattern match">(?=.*openssl).*</unix:filename>
    </unix:file_object>
    <independent:textfilecontent54_object xmlns:independent="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" id="oval:org.OpenSsl:obj:3" version="1">
      <independent:path>/usr/lib/apk/db</independent:path>
      <independent:filename>installed</independent:filename>
      <independent:pattern operation="pattern match">^P:openssl-config-fipshardened(-\d+\.\d+\.\d+)?$</independent:pattern>
      <independent:instance datatype="int">1</independent:instance>
    </independent:textfilecontent54_object>
    <independent:textfilecontent54_object xmlns:independent="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" id="oval:org.OpenSsl:obj:4" version="1">
      <independent:path>/usr/lib/apk/db</independent:path>
      <independent:filename>installed</independent:filename>
      <independent:pattern operation="pattern match">^P:openssl-provider-fips(-\d+\.\d+\.\d+)?$</independent:pattern>
      <independent:instance datatype="int">1</independent:instance>
    </independent:textfilecontent54_object>
    <independent:textfilecontent54_object xmlns:independent="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" id="oval:org.OpenSsl:obj:5" version="1">
      <independent:filepath>/etc/ssl/openssl.cnf</independent:filepath>
      <independent:pattern operation="pattern match">^\s*\.include\s+fipsmodule\.cnf\s*$</independent:pattern>
      <independent:instance datatype="int" operation="greater than or equal">1</independent:instance>
    </independent:textfilecontent54_object>
    <independent:textfilecontent54_object xmlns:independent="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" id="oval:org.OpenSsl:obj:6" version="1">
      <independent:filepath>/etc/ssl/openssl.cnf</independent:filepath>
      <independent:pattern operation="pattern match">^\s*fips\s*=\s*fips_sect\s*$</independent:pattern>
      <independent:instance datatype="int" operation="greater than or equal">1</independent:instance>
    </independent:textfilecontent54_object>
    <independent:textfilecontent54_object xmlns:independent="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" id="oval:org.OpenSsl:obj:7" version="1">
      <independent:filepath>/etc/ssl/openssl.cnf</independent:filepath>
      <independent:pattern operation="pattern match">^\s*default_properties\s*=\s*fips=yes\s*$</independent:pattern>
      <independent:instance datatype="int" operation="greater than or equal">1</independent:instance>
    </independent:textfilecontent54_object>
    <!-- obj:8 reads the OPENSSL_CONF environment variable configured on the
         scanned image/container. In offline mode oscap sources it from
         OSCAP_CONTAINER_VARS (the target's Config.Env), which oscap-docker
         populates. Paired with tst:8's any_exist + check=all, the criterion is
         satisfied when OPENSSL_CONF is unset OR set to /etc/ssl/openssl.cnf. -->
    <independent:environmentvariable58_object xmlns:independent="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent" id="oval:org.OpenSsl:obj:8" version="1">
      <independent:pid xsi:nil="true" datatype="int"/>
      <independent:name>OPENSSL_CONF</independent:name>
    </independent:environmentvariable58_object>
