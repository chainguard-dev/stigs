      <independent:filepath>/etc/ssh/ssh_config.d/10-ssh-fips.conf</independent:filepath>
      <independent:pattern operation="pattern match">^\s*Ciphers\s+aes128-gcm@openssh\.com,aes256-gcm@openssh\.com,aes256-ctr,aes192-ctr,aes128-ctr\s*$</independent:pattern>
